generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  password        String
  aktif           Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  teamType        String?
  roleId          String?
  adPerformances  AdPerformance[]
  auditLogs       AuditLog[]
  gajiPengajar    GajiPengajar[]
  gajiStaf        GajiStaf[]
  karyawanProfile KaryawanProfile?
  kelasAjar       Kelas[]          @relation("PengajarKelas")
  leads           Lead[]           @relation("CSLeads")
  liveSessions    LiveSession[]
  pemasukan       Pemasukan[]      @relation("CSPemasukan")
  pemasukanTalent Pemasukan[]      @relation("TalentPemasukan")
  pengeluaran     Pengeluaran[]
  refundsAsCS     Refund[]         @relation("CSRefund")
  refundsAsFin    Refund[]         @relation("FinanceRefund")
  spentAds        SpentAds[]
  role            Role?            @relation(fields: [roleId], references: [id])
}

model KaryawanProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  nik           String?  @unique
  posisi        String?
  bankName      String?
  rekeningNomor String?
  rekeningNama  String?
  gajiPokok     Float    @default(0)
  tunjangan     Float    @default(0)
  feeClosing    Float    @default(0)
  feeLead       Float    @default(0)
  bonusTarget   Int      @default(0)
  bonusNominal  Float    @default(0)
  keterangan    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LiveSession {
  id         String   @id @default(cuid())
  userId     String
  tanggal    DateTime @default(now())
  durasi     Float
  keterangan String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model GajiStaf {
  id           String      @id @default(cuid())
  userId       String
  bulan        Int
  tahun        Int
  gapok        Float
  tunjangan    Float
  fee          Float
  bonus        Float
  total        Float
  statusBayar  StatusBayar @default(BELUM_BAYAR)
  tanggalBayar DateTime?
  metodeBayar  MetodeBayar @default(TRANSFER)
  keterangan   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id])
}

model Program {
  id           String      @id @default(cuid())
  nama         String
  deskripsi    String?
  tipe         TipeKelas   @default(REGULAR)
  harga        Float
  durasiBuilan Int         @default(3)
  aktif        Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  durasi       String?
  kategoriFee  String?
  feeClosing   Float       @default(0)
  feeClosingRO Float       @default(0)
  isProfitSharing Boolean   @default(false)
  kelas        Kelas[]
  leads        Lead[]
  pemasukan    Pemasukan[]
}

model Siswa {
  id            String         @id @default(cuid())
  noSiswa       String         @unique
  nama          String
  telepon       String?
  email         String?
  alamat        String?
  tanggalLahir  DateTime?
  tanggalDaftar DateTime       @default(now())
  status        StatusSiswa    @default(AKTIF)
  catatan       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  absensi       Absensi[]
  invoice       Invoice[]
  kendalaMurid  KendalaMurid[]
  pemasukan     Pemasukan[]
  pendaftaran   Pendaftaran[]
  refunds       Refund[]
}

model Kelas {
  id             String         @id @default(cuid())
  namaKelas      String
  programId      String
  pengajarId     String?
  jadwal         String?
  hari           String?
  jam            String?
  kapasitas      Int            @default(10)
  status         StatusKelas    @default(AKTIF)
  tanggalMulai   DateTime?
  tanggalSelesai DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  durasi         String?
  linkGrup       String?
  feePerSesi     Float          @default(0)
  materiLink     String?
  gajiPengajar   GajiPengajar[]
  pengajar       User?          @relation("PengajarKelas", fields: [pengajarId], references: [id])
  program        Program        @relation(fields: [programId], references: [id])
  kendalaMurid   KendalaMurid[]
  materiKelas    MateriKelas[]
  pendaftaran    Pendaftaran[]
  sesiKelas      SesiKelas[]
}

model Pendaftaran {
  id             String    @id @default(cuid())
  siswaId        String
  kelasId        String
  tanggalDaftar  DateTime  @default(now())
  tanggalMulai   DateTime?
  tanggalSelesai DateTime?
  aktif          Boolean   @default(true)
  createdAt      DateTime  @default(now())
  kelas          Kelas     @relation(fields: [kelasId], references: [id])
  siswa          Siswa     @relation(fields: [siswaId], references: [id])

  @@unique([siswaId, kelasId])
}

model Pemasukan {
  id          String      @id @default(cuid())
  tanggal     DateTime    @default(now())
  siswaId     String?
  programId   String?
  csId        String?
  hargaNormal Float
  diskon      Float       @default(0)
  hargaFinal  Float
  metodeBayar MetodeBayar @default(CASH)
  keterangan  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isRO        Boolean     @default(false)
  talentId    String?
  invoice     Invoice?
  cs          User?       @relation("CSPemasukan", fields: [csId], references: [id])
  program     Program?    @relation(fields: [programId], references: [id])
  siswa       Siswa?      @relation(fields: [siswaId], references: [id])
  talent      User?       @relation("TalentPemasukan", fields: [talentId], references: [id])
  refunds     Refund[]
}

model Pengeluaran {
  id          String              @id @default(cuid())
  tanggal     DateTime            @default(now())
  jumlah      Float
  kategori    String              @default("LAINNYA")
  metodeBayar MetodeBayar         @default(CASH)
  keterangan  String?
  dibuatOleh  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User?               @relation(fields: [dibuatOleh], references: [id])
}

model SpentAds {
  id         String      @id @default(cuid())
  tanggal    DateTime    @default(now())
  platform   PlatformAds
  jumlah     Float
  keterangan String?
  dibuatOleh String?
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [dibuatOleh], references: [id])
}

model Invoice {
  id          String      @id @default(cuid())
  noInvoice   String      @unique
  pemasukanId String      @unique
  siswaId     String?
  tanggal     DateTime    @default(now())
  total       Float
  diskon      Float       @default(0)
  totalFinal  Float
  statusBayar StatusBayar @default(LUNAS)
  catatan     String?
  createdAt   DateTime    @default(now())
  pemasukan   Pemasukan   @relation(fields: [pemasukanId], references: [id])
  siswa       Siswa?      @relation(fields: [siswaId], references: [id])
}

model TarifPengajar {
  id          String    @id @default(cuid())
  tipeKelas   TipeKelas
  tarif       Float
  keterangan  String?
  berlakuDari DateTime  @default(now())
  aktif       Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model GajiPengajar {
  id           String      @id @default(cuid())
  pengajarId   String
  kelasId      String?
  bulan        Int
  tahun        Int
  jumlahSesi   Int         @default(0)
  tarifPerSesi Float
  totalGaji    Float
  statusBayar  StatusBayar @default(BELUM_BAYAR)
  tanggalBayar DateTime?
  metodeBayar  MetodeBayar @default(TRANSFER)
  keterangan   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  kelas        Kelas?      @relation(fields: [kelasId], references: [id])
  pengajar     User        @relation(fields: [pengajarId], references: [id])
}

model Inventaris {
  id          String            @id @default(cuid())
  nama        String
  kategori    String
  jumlah      Int               @default(0)
  satuan      String            @default("pcs")
  hargaBeli   Float?
  kondisi     KondisiInventaris @default(BAIK)
  tanggalBeli DateTime?
  keterangan  String?
  stokMinimum Int               @default(1)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Lead {
  id               String     @id @default(cuid())
  nama             String
  whatsapp         String
  email            String?
  preferensiJadwal String?
  followUpCount    Int        @default(0)
  programId        String?
  isRO             Boolean    @default(false)
  status           LeadStatus @default(NEW)
  kodeUnik         Int?
  nominalTagihan   Float?
  csId             String?
  keterangan       String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  cs               User?      @relation("CSLeads", fields: [csId], references: [id])
  program          Program?   @relation(fields: [programId], references: [id])
}

model SesiKelas {
  id        String     @id @default(cuid())
  kelasId   String
  topik     String
  tanggal   DateTime
  status    StatusSesi @default(DIJADWALKAN)
  catatan   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  absensi   Absensi[]
  kelas     Kelas      @relation(fields: [kelasId], references: [id], onDelete: Cascade)
}

model Absensi {
  id          String          @id @default(cuid())
  sesiKelasId String
  siswaId     String
  status      StatusKehadiran @default(HADIR)
  nilaiHuruf  String?
  nilaiAngka  Float?
  catatan     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  sesiKelas   SesiKelas       @relation(fields: [sesiKelasId], references: [id], onDelete: Cascade)
  siswa       Siswa           @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  @@unique([sesiKelasId, siswaId])
}

model MateriKelas {
  id           String   @id @default(cuid())
  kelasId      String
  judul        String
  deskripsi    String?
  urlFile      String
  diunggahOleh String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  kelas        Kelas    @relation(fields: [kelasId], references: [id], onDelete: Cascade)
}

model KendalaMurid {
  id             String   @id @default(cuid())
  kelasId        String
  siswaId        String
  dilaporkanOleh String
  topik          String
  deskripsi      String
  status         String   @default("OPEN")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  kelas          Kelas    @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  siswa          Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  target    String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Refund {
  id             String       @id @default(cuid())
  pemasukanId    String?
  invoiceId      String?
  siswaId        String
  csId           String
  financeId      String?
  jumlah         Float
  alasan         String
  rekeningTujuan String
  buktiChat      String?
  status         StatusRefund @default(PENDING)
  catatan        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  cs             User         @relation("CSRefund", fields: [csId], references: [id])
  finance        User?        @relation("FinanceRefund", fields: [financeId], references: [id])
  pemasukan      Pemasukan?   @relation(fields: [pemasukanId], references: [id])
  siswa          Siswa        @relation(fields: [siswaId], references: [id])
}

model WaTemplate {
  id        String   @id @default(cuid())
  label     String
  text      String
  updatedAt DateTime @updatedAt
}

model AdPerformance {
  id        String      @id @default(cuid())
  date      DateTime    @default(now())
  advId     String
  spent     Float
  leads     Int
  cpl       Float
  cpa       Float?
  fee       Float
  updatedAt DateTime    @updatedAt
  platform  PlatformAds @default(META)
  adv       User        @relation(fields: [advId], references: [id])

  @@index([advId])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("PermissionToRole")
}

enum TipeKelas {
  PRIVATE
  REGULAR
  SEMI_PRIVATE
  ONLINE
  LAINNYA
}

enum StatusSiswa {
  AKTIF
  TIDAK_AKTIF
  ALUMNI
}

enum StatusKehadiran {
  HADIR
  IZIN
  SAKIT
  ALPA
}

enum StatusSesi {
  DIJADWALKAN
  BERLANGSUNG
  SELESAI
  BATAL
}

enum LeadStatus {
  NEW
  FOLLOW_UP
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum StatusKelas {
  AKTIF
  SELESAI
  DIJADWALKAN
}

enum MetodeBayar {
  CASH
  TRANSFER
  QRIS
}

enum StatusBayar {
  LUNAS
  BELUM_BAYAR
  BATAL
}

enum StatusRefund {
  PENDING
  APPROVED
  REJECTED
}

model KategoriPengeluaran {
  id        String   @id @default(cuid())
  nama      String   @unique
  slug      String   @unique
  color     String?  @default("#ef4444")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlatformAds {
  GOOGLE
  META
  TIKTOK
  INSTAGRAM
  YOUTUBE
  LAINNYA
}

enum KondisiInventaris {
  BAIK
  RUSAK_RINGAN
  RUSAK_BERAT
}
